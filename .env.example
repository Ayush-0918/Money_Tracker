# ─────────────────────────────────────────────────────────────────────────────
# .env.example  ·  Money Tracker Backend
#
# HOW TO USE:
#   cp .env.example .env
#   # Fill in all values marked with <...>
#   # NEVER commit the .env file — it is in .gitignore
#
# SECURITY RULES:
#   - NEVER hardcode secrets in docker-compose.yml, CI files, or source code
#   - NEVER commit .env to git (it is gitignored)
#   - Rotate any secret that was accidentally committed
#   - Use `python -c "import secrets; print(secrets.token_hex(32))"` to generate keys
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# For local Docker: use the values below as-is
# For production (Supabase): Settings → Database → Connection string (URI)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://postgres:<YOUR_DB_PASSWORD>@db:5432/money_tracker

# ── Docker Postgres (local dev only) ─────────────────────────────────────────
# Must match the password in DATABASE_URL above
POSTGRES_PASSWORD=<choose-a-strong-local-password>

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 characters. Keep this private — compromise = anyone can forge tokens.
JWT_SECRET_KEY=<generate-with-secrets.token_hex(32)>
JWT_ALGORITHM=HS256
# Token expiry in minutes (10080 = 7 days)
JWT_EXPIRE_MINUTES=10080

# ── Admin API Key ─────────────────────────────────────────────────────────────
# Guards DELETE /admin/* endpoints
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
ADMIN_API_KEY=<generate-with-secrets.token_hex(16)>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
# For Android emulator local testing use: http://10.0.2.2:8080
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:8080

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | production

# ── AI Providers ─────────────────────────────────────────────────────────────
# Primary: Groq Cloud — https://console.groq.com/keys
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile

# Secondary fallback: GitHub Models — https://github.com/settings/tokens
GITHUB_TOKEN=<your-github-personal-access-token>
GITHUB_MODEL=openai/gpt-4.1
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com

# Enable or disable AI categorization entirely
AI_ENABLED=true

# AI provider request timeouts (seconds)
AI_TIMEOUT_GROQ=10.0
AI_TIMEOUT_GITHUB=10.0

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry DSN — leave blank to disable. Get from https://sentry.io
# SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_DSN=
