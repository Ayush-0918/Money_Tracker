# ─────────────────────────────────────────────────────────────────────────────
# .env.example  ·  Money Tracker Backend
#
# Copy this file to ".env" and fill in your real values.
# NEVER commit ".env" to version control — only this template.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string (URI)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://postgres:<YOUR_PASSWORD>@db.<YOUR_PROJECT_REF>.supabase.co:5432/postgres

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_secrets_token_hex_32
JWT_ALGORITHM=HS256
# Token expiry in minutes (10080 = 7 days)
JWT_EXPIRE_MINUTES=10080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
# For Android local testing use: http://10.0.2.2:8000
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:8000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max POST /transactions requests per user per minute
RATE_LIMIT_PER_MINUTE=20

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | production

# ── GitHub Models ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_MODEL=openai/gpt-4o
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
AI_ENABLED=true
